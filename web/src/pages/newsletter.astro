---
import Base from "../layouts/Base.astro";
import { API_URL } from "../lib/env";
---
<Base title="Join the VFSA Newsletter">
  <section class="max-w-2xl mx-auto px-4 py-12">
    <h1>Join the VFSA newsletter</h1>
    <p class="mt-3 text-slate-700">
      Get updates on Texas HB 6 implementation, advocacy opportunities, and
      resources for safer classrooms. Unsubscribe anytime.
    </p>

    <form id="newsletter-form" class="card mt-6 grid gap-3 sm:grid-cols-[1fr_auto]">
      <div>
        <label class="text-sm">Email</label>
        <input
          type="email"
          id="newsletter-email"
          name="email"
          class="input mt-1"
          placeholder="you@school.edu"
          required
        />
      </div>
      <button type="submit" class="btn btn-primary self-end">Subscribe</button>
    </form>
    <p id="newsletter-msg" class="mt-2 text-sm hidden"></p>
  </section>

  <script define:vars={{ API_URL }}>
    const form = document.getElementById("newsletter-form");
    const msg = document.getElementById("newsletter-msg");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = document.getElementById("newsletter-email").value.trim();
      msg.className = "mt-2 text-sm text-slate-600";
      msg.textContent = "Signing you up…";
      msg.classList.remove("hidden");
      try {
        const res = await fetch(`${API_URL.replace(/\/+$/, "")}/newsletter`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        if (!res.ok) throw new Error("Signup failed: " + res.status);
        msg.className = "mt-2 text-sm text-emerald-700";
        msg.textContent = "Thanks — you're on the list.";
        form.reset();
      } catch (err) {
        msg.className = "mt-2 text-sm text-red-700";
        msg.textContent = "Couldn't sign you up right now. Please try again later.";
        console.error(err);
      }
    });
  </script>
</Base>
