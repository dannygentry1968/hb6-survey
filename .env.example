# ---------------------------------------------------------
# HB 6 Survey — environment variables
# Copy this file to .env and fill in the values.
# ---------------------------------------------------------

# Public URL of the API (used by the web frontend on Netlify)
# Example: https://api.violencefreeschools.org
PUBLIC_API_URL=https://api.violencefreeschools.org

# Donate button destination (shown on the thank-you page)
DONATE_URL=https://www.gofundme.com/f/help-vfsa-make-schools-violencefree-zones

# ---------------------------------------------------------
# API-side (VPS Docker) variables
# ---------------------------------------------------------

# Postgres connection string — used by the API container.
# Inside docker-compose, "db" resolves to the Postgres service.
DATABASE_URL=postgresql://hb6:CHANGE_ME_STRONG_PASSWORD@db:5432/hb6?schema=public

# Postgres bootstrap credentials (used by the db service)
POSTGRES_USER=hb6
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=hb6

# Dashboard password (simple shared secret — change this!)
DASHBOARD_PASSWORD=CHANGE_ME_DASHBOARD_PASSWORD

# Random 32+ character string used to sign auth cookies
SESSION_SECRET=CHANGE_ME_RANDOM_AT_LEAST_32_CHARS_LONG_PLEASE

# CORS allow-list (comma separated). Add your Netlify preview URL here too.
CORS_ORIGINS=https://survey.violencefreeschools.org,https://violencefreeschools.org

# Public-facing domains for Caddy to provision TLS for
API_DOMAIN=api.violencefreeschools.org
DASHBOARD_DOMAIN=dashboard.violencefreeschools.org

# Email the certificate authority should use for Let's Encrypt notifications
ACME_EMAIL=mountainviewlearning@gmail.com

# API listen port (internal to Docker; Caddy reverse-proxies to this)
PORT=4000

# Node environment
NODE_ENV=production
